{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["GITHUB_TOKEN"],
      "outputs": ["dist/**"]
    },
    "seed": {
      "dependsOn": ["build"],
      "env": ["DATABASE_URL", "GITHUB_TOKEN", "GITHUB_OWNER", "GITHUB_REPO", "GITHUB_TAG"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
