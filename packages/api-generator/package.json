  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "dev": "tsdown --watch"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@ur-platform/eslint-config": "workspace:*",
